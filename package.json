{
  "name": "work-timer-app",
  "version": "2.0.0",
  "description": "Work timer with employer tracking",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.worktimer.app",
    "productName": "Work Timer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "mini/**/*",
      "preload/**/*",
      "shared/**/*",
      "package.json"
    ],
    "win": {
